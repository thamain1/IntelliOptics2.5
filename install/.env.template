ADMIN_PASSWORD=g@za8560EYAS
ADMIN_ROLES=admin,reviewer

# First-login bootstrap account (only created if missing; never overwritten)
BOOTSTRAP_ADMIN_EMAIL=admin@intellioptics.com
BOOTSTRAP_ADMIN_PASSWORD=admin123

# ==============================================================================
# ALERTS - Email
# ==============================================================================
# Get your API key at https://app.sendgrid.com → Settings → API Keys.
# NEVER commit a real key to this template — it will leak via git history.
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=jmorgan@4wardmotions.com

# ==============================================================================
# ALERTS - SMS (Optional)
# ==============================================================================
# Get Twilio credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=

# ==============================================================================
# APPLICATION
# ==============================================================================
APP_ENV=production
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost

# ==============================================================================
# EDGE DEVICE
# ==============================================================================
EDGE_DEVICE_ID=edge-prod-001
INTELLIOPTICS_API_TOKEN=

# Inference defaults
IO_IMG_SIZE=640
IO_CONF_THRESH=0.25
IO_NMS_IOU=0.45

# ==============================================================================
# PORTS
# ==============================================================================
# Change these if 80/443/30101 are already in use on the host.
CLOUD_HTTP_PORT=80
CLOUD_HTTPS_PORT=443
EDGE_PORT=30101
